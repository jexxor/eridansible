services:
  postgres:
    image: {{ datastore_postgres_image }}
    restart: unless-stopped
    env_file:
      - .env
    environment:
      POSTGRES_USER: "{{ datastore_postgres_user }}"
      POSTGRES_DB: "{{ datastore_postgres_db }}"
      POSTGRES_INITDB_ARGS: "--encoding=UTF-8 --lc-collate=C --lc-ctype=C"
    volumes:
      - ./postgres:/var/lib/postgresql/data
    ports:
      - "127.0.0.1:{{ datastore_postgres_host_port }}:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ datastore_postgres_user }} -d {{ datastore_postgres_db }}"]
      interval: 5s
      timeout: 5s
      retries: 12

  redis:
    image: {{ datastore_redis_image }}
    restart: unless-stopped
    command: ["redis-server", "--save", "", "--appendonly", "no"]
    ports:
      - "127.0.0.1:{{ datastore_redis_host_port }}:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5

{% set _pub = matrix_mas_http_public_base | default(matrix_base_public_baseurl ~ '/auth/', true) %}
{% set _iss = matrix_mas_http_issuer | default(matrix_base_public_baseurl ~ '/auth', true) %}
{% set _dbpw = matrix_mas_database_password | default(datastore_postgres_password, true) %}
{# MAS requires 64 hex chars (32 bytes). Pass through if already that; else SHA256(passphrase) hex (stable per vault value). #}
{% set _mas_enc_raw = matrix_mas_encryption_secret | string %}
{% set _mas_enc_mas = ((_mas_enc_raw | length == 64) and (_mas_enc_raw is match('^[0-9a-fA-F]{64}$')))
    | ternary(_mas_enc_raw | lower, _mas_enc_raw | hash('sha256')) %}
http:
  public_base: {{ _pub | to_json }}
  issuer: {{ _iss | to_json }}
  listeners:
    - name: web
      resources:
        - name: discovery
        - name: human
        - name: oauth
        - name: compat
        - name: graphql
          playground: false
        - name: assets
        - name: connection-info
      binds:
        - address: "0.0.0.0:8080"
          proxy_protocol: false
    - name: internal
      resources:
        - name: health
      binds:
        - host: 127.0.0.1
          port: 8081
          proxy_protocol: false
      trusted_proxies:
        - 192.168.0.0/16
        - 172.16.0.0/12
        - 10.0.0.0/10
        - 127.0.0.1/8
        - fd00::/8
        - ::1/128
account:
  password_registration_enabled: true
  registration_token_required: true
  displayname_change_allowed: true
  password_registration_email_required: false
policy:
  data:
    client_registration:
      allow_missing_contacts: true
      allow_missing_client_uri: true
      allow_host_mismatch: true
{% if matrix_mas_policy_admin_users | length > 0 %}
    admin_users:
{% for u in matrix_mas_policy_admin_users %}
      - {{ u | to_json }}
{% endfor %}
{% else %}
    admin_users: []
{% endif %}
database:
  uri: "postgresql://{{ datastore_postgres_user }}:{{ _dbpw }}@postgres/mas"
  max_connections: 10
  min_connections: 0
  connect_timeout: 30
  idle_timeout: 600
  max_lifetime: 1800
email:
  from: '"MAS" <root@localhost>'
  reply_to: '"MAS" <root@localhost>'
  transport: blackhole
secrets:
  encryption: {{ _mas_enc_mas | to_json }}
  keys:
    - kid: ansible-rsa
      key: |
{{ matrix_mas_rsa_private_key_pem | indent(8, True) }}
passwords:
  enabled: true
  schemes:
    - version: 1
      algorithm: bcrypt
  minimum_complexity: 3
  registration_enabled: true
  registration_token_mandatory: true
matrix:
  homeserver: {{ matrix_base_server_name | to_json }}
  secret: {{ matrix_mas_matrix_secret | to_json }}
  endpoint: "http://synapse:8008/"
clients:
  - client_id: {{ matrix_mas_synapse_client_id | to_json }}
    client_auth_method: client_secret_post
    client_secret: {{ matrix_mas_synapse_client_secret | to_json }}
    redirect_uris:
      - "{{ matrix_base_public_baseurl }}/_synapse/client/oidc/callback"
  - client_id: {{ matrix_mas_compat_client_id | to_json }}
    client_auth_method: client_secret_post
    client_secret: {{ matrix_mas_compat_client_secret | to_json }}
    redirect_uris:
      - "{{ matrix_base_public_baseurl }}/auth/api/doc/oauth2-redirect.html"

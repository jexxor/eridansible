services:
  synapse:
    image: {{ matrix_base_synapse_image }}
    user: "{{ matrix_base_synapse_uid }}:{{ matrix_base_synapse_gid }}"
    restart: unless-stopped
    environment:
      SYNAPSE_CONFIG_PATH: /data/homeserver.yaml
    volumes:
      - ./data:/data
    networks:
      - matrix_app
      - datastores_net
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          python3 -c "import urllib.request as u; u.urlopen('http://127.0.0.1:8008/_matrix/client/versions', timeout=5).read()"
      interval: 15s
      timeout: 10s
      retries: 12
      start_period: 90s

  element-web:
    image: {{ matrix_base_element_image }}
    restart: unless-stopped
    volumes:
      - ./element/config.json:/app/config.json:ro
    networks:
      - matrix_app
    depends_on:
      synapse:
        condition: service_started

{% for w in matrix_base_workers_effective | default([]) %}
  synapse-worker-{{ w.name | replace('_', '-') }}:
    image: {{ matrix_base_synapse_image }}
    restart: unless-stopped
    user: "{{ matrix_base_synapse_uid }}:{{ matrix_base_synapse_gid }}"
    command:
      - run
      - -m
      - synapse.app.generic_worker
      - --config-path=/data/homeserver.yaml
      - --config-path=/data/workers/{{ w.name }}.yaml
    volumes:
      - ./data:/data
    networks:
      - matrix_app
      - datastores_net
    depends_on:
      synapse:
        condition: service_started
    healthcheck:
      disable: true
{% endfor %}

networks:
  matrix_app:
    name: matrix_base_default
    driver: bridge
  datastores_net:
    external: true
    name: datastores_default
